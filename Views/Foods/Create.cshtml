@model GlycemicTracker.Models.Food
@{
    ViewData["Title"] = "Add Custom Food";
}

<div class="row justify-content-center">
    <div class="col-lg-8 col-xl-6">
        <div class="glass-panel">
            <h2 class="mb-2 text-info">Add Custom Food</h2>
            <p class="text-secondary mb-4">Register nutritional info for a new food item. All values should be per 100g portion.</p>

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label asp-for="Name" class="form-label text-secondary"></label>
                    <input asp-for="Name" class="form-control" placeholder="e.g. Grandma's Chocolate Chip Cookies" required />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="GlycemicIndex" class="form-label text-secondary"></label>
                        <input asp-for="GlycemicIndex" type="number" class="form-control" min="0" max="100" required />
                        <span asp-validation-for="GlycemicIndex" class="text-danger small"></span>
                        <div class="form-text text-muted" style="font-size:0.75rem;">0 for carbless items. High: &ge;70, Med: 56-69, Low: &le;55.</div>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="CaloriesPer100g" class="form-label text-secondary"></label>
                        <input asp-for="CaloriesPer100g" type="number" class="form-control" min="0" max="950" required />
                        <span asp-validation-for="CaloriesPer100g" class="text-danger small"></span>
                        <div class="form-text text-muted" style="font-size:0.75rem;">Energy value in kilocalories (kcal).</div>
                    </div>
                </div>

                <h5 class="mt-4 mb-3 border-bottom pb-2" style="border-color: var(--border-color) !important;">Macronutrients (per 100g)</h5>

                <div class="row g-3 mb-3">
                    <div class="col-6 col-md-4">
                        <label asp-for="CarbsPer100g" class="form-label text-secondary"></label>
                        <div class="input-group">
                            <input asp-for="CarbsPer100g" type="number" step="0.1" class="form-control" min="0" max="100" required />
                            <span class="input-group-text bg-dark border-secondary text-secondary">g</span>
                        </div>
                        <span asp-validation-for="CarbsPer100g" class="text-danger small"></span>
                    </div>
                    <div class="col-6 col-md-4">
                        <label asp-for="SugarPer100g" class="form-label text-secondary"></label>
                        <div class="input-group">
                            <input asp-for="SugarPer100g" type="number" step="0.1" class="form-control" min="0" max="100" required />
                            <span class="input-group-text bg-dark border-secondary text-secondary">g</span>
                        </div>
                        <span asp-validation-for="SugarPer100g" class="text-danger small"></span>
                    </div>
                    <div class="col-6 col-md-4">
                        <label asp-for="FiberPer100g" class="form-label text-secondary"></label>
                        <div class="input-group">
                            <input asp-for="FiberPer100g" type="number" step="0.1" class="form-control" min="0" max="100" required />
                            <span class="input-group-text bg-dark border-secondary text-secondary">g</span>
                        </div>
                        <span asp-validation-for="FiberPer100g" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-6">
                        <label asp-for="ProteinPer100g" class="form-label text-secondary"></label>
                        <div class="input-group">
                            <input asp-for="ProteinPer100g" type="number" step="0.1" class="form-control" min="0" max="100" required />
                            <span class="input-group-text bg-dark border-secondary text-secondary">g</span>
                        </div>
                        <span asp-validation-for="ProteinPer100g" class="text-danger small"></span>
                    </div>
                    <div class="col-6">
                        <label asp-for="FatPer100g" class="form-label text-secondary"></label>
                        <div class="input-group">
                            <input asp-for="FatPer100g" type="number" step="0.1" class="form-control" min="0" max="100" required />
                            <span class="input-group-text bg-dark border-secondary text-secondary">g</span>
                        </div>
                        <span asp-validation-for="FatPer100g" class="text-danger small"></span>
                    </div>
                </div>

                <div class="d-flex justify-content-between">
                    <a class="btn btn-secondary px-4" asp-action="Index">Cancel</a>
                    <button type="submit" class="btn btn-primary px-5">Add Food</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Enable client side validation -->
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
}
