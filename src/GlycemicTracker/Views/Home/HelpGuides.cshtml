        </div>

        <!-- Tab Content -->
        <div class="col-lg-9">
            <div class="tab-content" id="v-pills-tabContent">
                
                <!-- GUIDE 1: Morning Glucose Reset Routine -->
                <div class="tab-pane fade show active" id="v-pills-reset" role="tabpanel" aria-labelledby="v-pills-reset-tab">
                    <div class="card glass-panel border-success shadow" style="background: rgba(16, 185, 129, 0.01);">
                        <div class="card-body p-2">
                            <div class="d-flex align-items-center mb-3">
                                <span class="p-3 bg-success rounded-circle me-3 d-flex align-items-center justify-content-center" style="--bs-bg-opacity: 0.1; width: 56px; height: 56px;">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" class="bi bi-sunrise-fill text-success" viewBox="0 0 16 16">
                                        <path d="M7.646 1.146a.5.5 0 0 1 .708 0l1.5 1.5a.5.5 0 0 1-.708.708L8.5 2.707V4.5a.5.5 0 0 1-1 0V2.707L6.854 3.354a.5.5 0 1 1-.708-.708l1.5-1.5zM3 10.5a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3.5a.5.5 0 0 1-.5-.5zm.5 3a.5.5 0 0 0 0 1h10a.5.5 0 0 0 0-1H3.5zM14 10a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 0 1h-1a.5.5 0 0 1-.5-.5zm-12 0a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 0 1H2.5A.5.5 0 0 1 2 10z"/>
                                        <path fill-rule="evenodd" d="M13.5 10a.5.5 0 0 1-.5-.5 5 5 0 0 0-10 0 .5.5 0 0 1-1 0 6 6 0 1 1 12 0 .5.5 0 0 1-.5.5z"/>
                                    </svg>
                                </span>
                                <div>
                                    <h3 class="text-white mb-0">Morning Glucose Reset Routine</h3>
                                    <span class="text-secondary small">Waking sequence to combat the Dawn Phenomenon</span>
                                </div>
                            </div>

                            <p class="text-secondary mb-4">
                                When you wake up, cortisol and growth hormone dumps trigger your liver to release glucose into the bloodstream (known as the **Dawn Phenomenon**). Because you have not eaten overnight, this spike happens without dietary carbs. 
                                Performing this simple 3-minute sequence immediately upon getting out of bed will activate muscles to sink glucose, calm stress hormones, and rehydrate your system.
                            </p>

                            <!-- Checkable Steps -->
                            <h5 class="text-white fw-bold mb-3"><i class="bi bi-patch-check text-success me-2"></i>Waking Step List</h5>
                            
                            <div class="d-flex flex-column gap-3 mb-4">
                                <!-- Step 1 -->
                                <div class="routine-step-item d-flex align-items-start p-3 rounded glass-panel" style="background: rgba(255,255,255,0.01);">
                                    <div class="form-check me-3 mt-1">
                                        <input class="form-check-input routine-checkbox" type="checkbox" id="checkStep1" data-step="1" style="transform: scale(1.25); cursor: pointer;">
                                    </div>
                                    <div>
                                        <label for="checkStep1" class="text-white h6 mb-1 fw-bold cursor-pointer">1. 10 Slow Squats</label>
                                        <p class="text-secondary small mb-0">
                                            Activates the quadriceps and glutes (the body's largest muscle groups). This mechanical contraction pulls glucose directly from the bloodstream to replenish glycogen stores, bypassing insulin requirements.
                                        </p>
                                    </div>
                                </div>

                                <!-- Step 2 -->
                                <div class="routine-step-item d-flex align-items-start p-3 rounded glass-panel" style="background: rgba(255,255,255,0.01);">
                                    <div class="form-check me-3 mt-1">
                                        <input class="form-check-input routine-checkbox" type="checkbox" id="checkStep2" data-step="2" style="transform: scale(1.25); cursor: pointer;">
                                    </div>
                                    <div>
                                        <label for="checkStep2" class="text-white h6 mb-1 fw-bold cursor-pointer">2. 10 Knee Marches (Per Leg)</label>
                                        <p class="text-secondary small mb-0">
                                            Stimulates pelvic and lower-body circulation, gently raises metabolic rate, and encourages lymphatic drainage.
                                        </p>
                                    </div>
                                </div>

                                <!-- Step 3 -->
                                <div class="routine-step-item d-flex align-items-start p-3 rounded glass-panel" style="background: rgba(255,255,255,0.01);">
                                    <div class="form-check me-3 mt-1">
                                        <input class="form-check-input routine-checkbox" type="checkbox" id="checkStep3" data-step="3" style="transform: scale(1.25); cursor: pointer;">
                                    </div>
                                    <div>
                                        <label for="checkStep3" class="text-white h6 mb-1 fw-bold cursor-pointer">3. 10 Calf Raises (Calf Lifts)</label>
                                        <p class="text-secondary small mb-0">
                                            Engages the soleus muscle. The soleus has a unique oxidative profile that relies primarily on blood glucose and lipids rather than stored glycogen. Tapping the soleus is highly effective for clearing circulating sugars.
                                        </p>
                                    </div>
                                </div>

                                <!-- Step 4 -->
                                <div class="routine-step-item d-flex align-items-start p-3 rounded glass-panel" style="background: rgba(255,255,255,0.01);">
                                    <div class="form-check me-3 mt-1">
                                        <input class="form-check-input routine-checkbox" type="checkbox" id="checkStep4" data-step="4" style="transform: scale(1.25); cursor: pointer;">
                                    </div>
                                    <div class="w-100">
                                        <label for="checkStep4" class="text-white h6 mb-1 fw-bold cursor-pointer">4. 4x4 Box Breathing Cycle</label>
                                        <p class="text-secondary small mb-3">
                                            Repeat the cycle: Inhale (4s) &rarr; Hold (4s) &rarr; Exhale (4s) &rarr; Hold (4s) exactly 4 times. This stimulation triggers the vagal parasympathetic nervous system, lowering waking cortisol dumps and stress-related liver gluconeogenesis.
                                        </p>

                                        <!-- Interactive Box Breathing Widget -->
                                        <div class="breathing-widget-container p-3 rounded border border-secondary text-center" style="background: rgba(10, 14, 23, 0.4); border-color: rgba(255, 255, 255, 0.1) !important;">
                                            <div class="d-flex justify-content-between align-items-center mb-2 px-2">
                                                <span class="text-secondary small">Box Breathing Aid</span>
                                                <span class="badge bg-secondary" id="cycleBadge">Cycle: 0 / 4</span>
                                            </div>
                                            
                                            <div class="d-flex justify-content-center align-items-center py-4">
                                                <div class="breathing-circle" id="breathCircle">
                                                    <div class="d-flex flex-column text-center">
                                                        <span class="fw-bold text-white small" id="breathText" style="letter-spacing: 0.05em; font-family: 'Montserrat', sans-serif;">READY</span>
                                                        <span class="display-6 fw-bold text-white" id="breathTimer">--</span>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="d-flex justify-content-center gap-2">
                                                <button type="button" class="btn btn-sm btn-outline-success" id="btnStartBreathing">
                                                    <i class="bi bi-play-fill me-1"></i>Start Guide
                                                </button>
                                                <button type="button" class="btn btn-sm btn-outline-danger d-none" id="btnStopBreathing">
                                                    <i class="bi bi-stop-fill me-1"></i>Stop
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Step 5 -->
                                <div class="routine-step-item d-flex align-items-start p-3 rounded glass-panel" style="background: rgba(255,255,255,0.01);">
                                    <div class="form-check me-3 mt-1">
                                        <input class="form-check-input routine-checkbox" type="checkbox" id="checkStep5" data-step="5" style="transform: scale(1.25); cursor: pointer;">
                                    </div>
                                    <div>
                                        <label for="checkStep5" class="text-white h6 mb-1 fw-bold cursor-pointer">5. Drink 1/2 Pint of Water</label>
                                        <p class="text-secondary small mb-0">
                                            Rehydrates the body from overnight sweat and breath moisture loss. Increasing blood plasma volume naturally dilutes glucose concentration without requiring any glucose disposal.
                                        </p>
                                    </div>
                                </div>
                            </div>

                            <div class="text-center py-2">
                                <button type="button" class="btn btn-outline-secondary btn-sm" id="btnClearChecks">
                                    <i class="bi bi-arrow-counterclockwise me-1"></i>Reset Today's Checklist
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- GUIDE 2: Post-Meal Glucose Clearance -->
                <div class="tab-pane fade" id="v-pills-postmeal" role="tabpanel" aria-labelledby="v-pills-postmeal-tab">
                    <div class="card glass-panel border-info shadow" style="background: rgba(14, 165, 233, 0.01);">
                        <div class="card-body p-2">
                            <div class="d-flex align-items-center mb-3">
                                <span class="p-3 bg-info rounded-circle me-3 d-flex align-items-center justify-content-center" style="--bs-bg-opacity: 0.1; width: 56px; height: 56px;">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="var(--color-accent-blue)" class="bi bi-activity text-info" viewBox="0 0 16 16">
                                        <path fill-rule="evenodd" d="M6 2a.5.5 0 0 1 .47.33L10 12.036l1.53-4.22a.5.5 0 0 1 .94 0L14.62 12l.76-2.28a.5.5 0 1 1 .95.316l-1.5 4.5a.5.5 0 0 1-.947 0L12 8.24l-1.53 4.22a.5.5 0 0 1-.94 0L7.38 3.964 5.38 9.964a.5.5 0 0 1-.95 0L3.13 6.098 1.83 9.998a.5.5 0 0 1-.95-.316l2-6a.5.5 0 0 1 .95 0L5.12 7.73l1.53-4.59A.5.5 0 0 1 7 3z"/>
                                    </svg>
                                </span>
                                <div>
                                    <h3 class="text-white mb-0">Post-Meal Glucose Clearance</h3>
                                    <span class="text-secondary small">Reducing glycemic load peaks using active muscles</span>
                                </div>
                            </div>

                            <p class="text-secondary mb-4">
                                When you eat food, your body breaks down carbohydrates into glucose. This glucose enters your blood, causing a spike. 
                                Typically, insulin is released to open cells and clear this glucose. However, when you have **insulin resistance**, cells are slow to respond, causing the spike to stay higher and last longer, damaging tissue and exhausting the pancreas.
                            </p>

                            <div class="row g-3 mb-4">
                                <div class="col-md-6">
                                    <div class="p-3 rounded border border-secondary h-100" style="background: rgba(255,255,255,0.02); border-color: rgba(255,255,255,0.1) !important;">
                                        <h6 class="text-info fw-bold mb-2"><i class="bi bi-clock-history me-2"></i>The 30-Minute Window</h6>
                                        <p class="text-secondary small mb-0">
                                            The optimal time to start moving is **within 30 minutes** after finishing a meal. This is when the glucose starts entering the bloodstream from the small intestine, and muscles are ready to consume it immediately.
                                        </p>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="p-3 rounded border border-secondary h-100" style="background: rgba(255,255,255,0.02); border-color: rgba(255,255,255,0.1) !important;">
                                        <h6 class="text-info fw-bold mb-2"><i class="bi bi-lightning-charge me-2"></i>GLUT4 Translocation</h6>
                                        <p class="text-secondary small mb-0">
                                            Muscle contraction triggers the movement of glucose transporters (GLUT4) to the cell surface, allowing cells to take up glucose **without** insulin. This lowers the workload on your pancreas.
                                        </p>
                                    </div>
                                </div>
                            </div>

                            <h5 class="text-white fw-bold mb-3"><i class="bi bi-arrow-right-short text-info fs-4 align-middle"></i>Actionable Strategies</h5>
                            <ul class="text-secondary small ps-3 mb-0">
                                <li class="mb-2"><strong>A 15-Minute Walk:</strong> A steady, casual walk is sufficient. There is no need for high-intensity exercise; consistent muscle movement is key.</li>
                                <li class="mb-2"><strong>Soleus Seated Pushups:</strong> If stuck at a desk, repeatedly bounce your heels while keeping your toes planted. This activates the soleus muscle, consuming glucose locally.</li>
                                <li class="mb-2"><strong>Kitchen Cleanup:</strong> Doing dishes, sweeping, or organizing for 10 minutes right after eating provides the light muscle contraction needed.</li>
                            </ul>
                        </div>
                    </div>
                </div>

                <!-- GUIDE 3: Sleep & Circadian Spikes -->
                <div class="tab-pane fade" id="v-pills-sleep" role="tabpanel" aria-labelledby="v-pills-sleep-tab">
                    <div class="card glass-panel border-warning shadow" style="background: rgba(245, 158, 11, 0.01);">
                        <div class="card-body p-2">
                            <div class="d-flex align-items-center mb-3">
                                <span class="p-3 bg-warning rounded-circle me-3 d-flex align-items-center justify-content-center" style="--bs-bg-opacity: 0.1; width: 56px; height: 56px;">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="var(--color-accent-orange)" class="bi bi-moon-stars-fill text-warning" viewBox="0 0 16 16">
                                        <path d="M6 .278a.768.768 0 0 1 .08.858 7.208 7.208 0 0 0-.878 3.46c0 4.021 3.278 7.277 7.318 7.277.527 0 1.04-.055 1.533-.16a.787.787 0 0 1 .81.316.733.733 0 0 1-.031.893A8.349 8.349 0 0 1 8.344 16C3.734 16 0 12.286 0 7.71 0 4.266 2.114 1.312 5.124.06A.752.752 0 0 1 6 .278z"/>
                                        <path d="M10.794 3.148a.217.217 0 0 1 .412 0l.387 1.162c.173.518.579.924 1.097 1.097l1.162.387a.217.217 0 0 1 0 .412l-1.162.387a1.734 1.734 0 0 0-1.097 1.097l-.387 1.162a.217.217 0 0 1-.412 0l-.387-1.162a1.734 1.734 0 0 0-1.097-1.097l-1.162-.387a.217.217 0 0 1 0-.412l1.162-.387a1.734 1.734 0 0 0 1.097-1.097l.387-1.162zM9.374 8.28a.145.145 0 0 1 .276 0l.258.775c.115.346.386.617.732.732l.775.258a.145.145 0 0 1 0 .276l-.775.258a1.156 1.156 0 0 0-.732.732l-.258.775a.145.145 0 0 1-.276 0l-.258-.775a1.156 1.156 0 0 0-.732-.732l-.775-.258a.145.145 0 0 1 0-.276l.775-.258c.346-.115.617-.386.732-.732l.258-.775z"/>
                                    </svg>
                                </span>
                                <div>
                                    <h3 class="text-white mb-0">Sleep & Circadian Glycemic Control</h3>
                                    <span class="text-secondary small">How poor sleep triggers morning glucose dumps</span>
                                </div>
                            </div>

                            <p class="text-secondary mb-4">
                                Sleep is a primary regulator of your metabolic system. During deep slow-wave sleep, your brain reduces glucose consumption, and insulin sensitivity is optimized. 
                                Disruptions in sleep trigger counter-regulatory hormones (cortisol, growth hormone, adrenaline) that raise blood glucose levels.
                            </p>

                            <div class="row g-3 mb-4">
                                <div class="col-md-6">
                                    <div class="p-3 rounded border border-secondary h-100" style="background: rgba(255,255,255,0.02); border-color: rgba(255,255,255,0.1) !important;">
                                        <h6 class="text-warning fw-bold mb-2"><i class="bi bi-exclamation-triangle-fill me-2"></i>Cortisol & Insulin Resistance</h6>
                                        <p class="text-secondary small mb-0">
                                            Restricting sleep to under 6 hours raises next-day cortisol. Cortisol stimulates glucose production in the liver (gluconeogenesis) and blocks insulin receptors, causing higher spikes from breakfast.
                                        </p>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="p-3 rounded border border-secondary h-100" style="background: rgba(255,255,255,0.02); border-color: rgba(255,255,255,0.1) !important;">
                                        <h6 class="text-warning fw-bold mb-2"><i class="bi bi-activity me-2"></i>Exaggerated Dawn Phenomenon</h6>
                                        <p class="text-secondary small mb-0">
                                            A stressful night or light sleep leads to an exaggerated early morning release of stress hormones, which amplifies the Dawn Phenomenon amplitude, pushing fasting glucose above baseline.
                                        </p>
                                    </div>
                                </div>
                            </div>

                            <h5 class="text-white fw-bold mb-3"><i class="bi bi-check-circle text-warning me-2"></i>Glycemic Sleep Hygiene Checklist</h5>
                            <ul class="text-secondary small ps-3 mb-0">
                                <li class="mb-2"><strong>The 3-Hour Dinner Rule:</strong> Avoid eating large meals within 3 hours of bed. Processing carbohydrates overnight leads to nocturnal spikes and high morning fasting readings.</li>
                                <li class="mb-2"><strong>Block Blue Light:</strong> Dim screens or wear amber glasses after 8:00 PM. Melatonin suppression raises stress levels and alters nighttime metabolism.</li>
                                <li class="mb-2"><strong>Cool Room Temperature:</strong> Keeping the room at around 18°C (65°F) encourages deep sleep and keeps sympathetic nervous activity low, lowering next-day cortisol.</li>
                            </ul>
                        </div>
                    </div>
                </div>

                <!-- GUIDE 4: Hydration Loading Strategy -->
                <div class="tab-pane fade" id="v-pills-hydration" role="tabpanel" aria-labelledby="v-pills-hydration-tab">
                    <div class="card glass-panel border-primary shadow" style="background: rgba(14, 165, 233, 0.01);">
                        <div class="card-body p-2">
                            <div class="d-flex align-items-center mb-3">
                                <span class="p-3 bg-primary rounded-circle me-3 d-flex align-items-center justify-content-center" style="--bs-bg-opacity: 0.1; width: 56px; height: 56px;">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="var(--color-accent-blue)" class="bi bi-droplet-fill text-primary" viewBox="0 0 16 16">
                                        <path fill-rule="evenodd" d="M8 16a6 6 0 0 1-6-6c0-1.655.77-3.424 1.886-5.087.462-.689.96-1.336 1.486-1.93.53-.597 1.074-1.12 1.6-1.543a.5.5 0 0 1 .657 0c.526.423 1.07 1.01 1.601 1.602.53.59.996 1.24 1.44 1.917C13.23 6.574 14 8.345 14 10a6 6 0 0 1-6 6zM8 4.253c-.818.847-1.637 1.815-2.28 2.783-.559.84-.969 1.632-.969 2.222 0 1.77 1.42 3.197 3.19 3.25a.5.5 0 0 0 .025-1c-1.22-.036-2.19-.99-2.215-2.25-.004-.2.073-.77.585-1.547.534-.81 1.256-1.712 1.914-2.392A.5.5 0 0 0 8 4.253z"/>
                                    </svg>
                                </span>
                                <div>
                                    <h3 class="text-white mb-0">Hydration Loading Strategy</h3>
                                    <span class="text-secondary small">Optimizing blood volume and sleep quality</span>
                                </div>
                            </div>

                            <p class="text-secondary mb-4">
                                Water is one of the most direct and overlooked modulators of blood glucose concentration. When you are dehydrated, your blood plasma volume decreases, which mechanically concentrates the glucose in your bloodstream, raising your readings. Proper hydration keeps blood flowing smoothly and allows your kidneys to naturally filter out excess glucose through urine.
                            </p>

                            <div class="row g-3 mb-4">
                                <div class="col-md-6">
                                    <div class="p-3 rounded border border-secondary h-100" style="background: rgba(255,255,255,0.02); border-color: rgba(255,255,255,0.1) !important;">
                                        <h6 class="text-info fw-bold mb-2"><i class="bi bi-clock-history me-2"></i>Daytime "Loading"</h6>
                                        <p class="text-secondary small mb-0">
                                            Consume the majority of your daily water intake (e.g., 2-3 liters) between **waking and mid-afternoon**. This "front-loads" your hydration when your metabolic activity, physical movement, and insulin action are highest, facilitating optimal kidney clearance.
                                        </p>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="p-3 rounded border border-secondary h-100" style="background: rgba(255,255,255,0.02); border-color: rgba(255,255,255,0.1) !important;">
                                        <h6 class="text-info fw-bold mb-2"><i class="bi bi-moon-stars me-2"></i>The 3-Hour Nocturnal Stop</h6>
                                        <p class="text-secondary small mb-0">
                                            Taper off and **stop drinking large volumes of fluids roughly 3 hours before bedtime**. While a sip is fine for dry mouth, large amounts of water close to sleep lead to waking up to urinate (nocturia), which breaks deep slow-wave sleep cycles.
                                        </p>
                                    </div>
                                </div>
                            </div>

                            <h5 class="text-white fw-bold mb-3"><i class="bi bi-shield-check text-info me-2"></i>The Hydration-Sleep Connection</h5>
                            <p class="text-secondary small mb-3">
                                Waking up even once in the middle of the night to use the restroom disrupts your circadian rhythm. Studies show that fragmented sleep, especially loss of deep slow-wave sleep:
                            </p>
                            <ul class="text-secondary small ps-3 mb-0">
                                <li class="mb-2">Increases sympathetic (fight-or-flight) activity overnight, elevating morning adrenaline and cortisol.</li>
                                <li class="mb-2">Exaggerates the next morning's **Dawn Phenomenon** spike from the liver.</li>
                                <li class="mb-2">Reduces overall insulin sensitivity the following day by up to 25%, causing larger post-meal spikes.</li>
                            </ul>
                        </div>
                    </div>
                </div>

                <!-- GUIDE 5: FAQ -->
                <div class="tab-pane fade" id="v-pills-faq" role="tabpanel" aria-labelledby="v-pills-faq-tab">
                    <div class="card glass-panel border-danger shadow" style="background: rgba(239, 68, 68, 0.01);">
                        <div class="card-body p-2">
                            <div class="d-flex align-items-center mb-3">
                                <span class="p-3 bg-danger rounded-circle me-3 d-flex align-items-center justify-content-center" style="--bs-bg-opacity: 0.1; width: 56px; height: 56px;">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="var(--color-accent-red)" class="bi bi-question-circle text-danger" viewBox="0 0 16 16">
                                        <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                                        <path d="M5.255 5.786a.237.237 0 0 0 .241.247h.825c.138 0 .248-.113.266-.25.09-.656.54-1.134 1.342-1.134.686 0 1.314.343 1.314 1.168 0 .635-.374.927-.965 1.371-.673.489-1.206 1.06-1.168 1.987l.003.217a.25.25 0 0 0 .25.246h.811a.25.25 0 0 0 .25-.25v-.105c0-.718.273-.927 1.01-1.486.609-.463 1.244-.977 1.244-2.056 0-1.511-1.276-2.241-2.673-2.241-1.267 0-2.655.59-2.75 2.286zm1.557 5.763c0 .533.425.927 1.01.927.609 0 1.028-.394 1.028-.927 0-.552-.42-.94-1.029-.94-.584 0-1.01.388-1.01.94z"/>
                                    </svg>
                                </span>
                                <div>
                                    <h3 class="text-white mb-0">Glycemic Index FAQ</h3>
                                    <span class="text-secondary small">Understanding GI, Glycemic Load, and spikes</span>
                                </div>
                            </div>

                            <div class="accordion accordion-flush bg-transparent" id="faqAccordion">
                                
                                <div class="accordion-item bg-transparent border-secondary text-white py-2" style="border-color: rgba(255, 255, 255, 0.1) !important;">
                                    <h2 class="accordion-header" id="headingOne">
                                        <button class="accordion-button bg-transparent text-white collapsed fw-bold px-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#collapseOne" aria-expanded="false" aria-controls="collapseOne">
                                            What is the difference between Glycemic Index (GI) and Glycemic Load (GL)?
                                        </button>
                                    </h2>
                                    <div id="collapseOne" class="accordion-collapse collapse" aria-labelledby="headingOne" data-bs-parent="#faqAccordion">
                                        <div class="accordion-body text-secondary small px-0">
                                            <strong>Glycemic Index (GI)</strong> measures *how fast* a carbohydrate turns into glucose compared to pure glucose (rated 0 to 100). 
                                            <strong>Glycemic Load (GL)</strong> measures *how much* carbohydrate is in an actual portion of food, calculated as:
                                            <div class="my-2 p-2 rounded text-center border border-secondary text-info" style="font-family: monospace; background: rgba(0,0,0,0.2); border-color: rgba(255, 255, 255, 0.1) !important;">
                                                GL = (GI &times; Carbs per portion in grams) / 100
                                            </div>
                                            A food can have a high GI (e.g., watermelon, GI 72) but a low GL (GL 4) because the carbohydrate content in a standard serving is low.
                                        </div>
                                    </div>
                                </div>

                                <div class="accordion-item bg-transparent border-secondary text-white py-2" style="border-color: rgba(255, 255, 255, 0.1) !important;">
                                    <h2 class="accordion-header" id="headingTwo">
                                        <button class="accordion-button bg-transparent text-white collapsed fw-bold px-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#collapseTwo" aria-expanded="false" aria-controls="collapseTwo">
                                            How can I lower the glycemic load of a meal?
                                        </button>
                                    </h2>
                                    <div id="collapseTwo" class="accordion-collapse collapse" aria-labelledby="headingTwo" data-bs-parent="#faqAccordion">
                                        <div class="accordion-body text-secondary small px-0">
                                            You can lower the glycemic load and speed of absorption of a meal by:
                                            <ul class="mt-2 ps-3">
                                                <li class="mb-1"><strong>Adding Fat & Protein:</strong> Eating carbs alongside cheese, meat, nuts, or avocados slows stomach emptying.</li>
                                                <li class="mb-1"><strong>Adding Soluble Fiber:</strong> Fiber creates a viscous gel that slows the digestion and absorption of glucose.</li>
                                                <li class="mb-1"><strong>Applying Acid:</strong> Vinegar (e.g. apple cider vinegar) or lemon juice slows gastric emptying and blocks enzymes that digest starch.</li>
                                            </ul>
                                        </div>
                                    </div>
                                </div>

                                <div class="accordion-item bg-transparent border-secondary text-white py-2" style="border-color: rgba(255, 255, 255, 0.1) !important;">
                                    <h2 class="accordion-header" id="headingThree">
                                        <button class="accordion-button bg-transparent text-white collapsed fw-bold px-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#collapseThree" aria-expanded="false" aria-controls="collapseThree">
                                            Why does the simulator show a peak 1.5 to 2 hours after eating?
                                        </button>
                                    </h2>
                                    <div id="collapseThree" class="accordion-collapse collapse" aria-labelledby="headingThree" data-bs-parent="#faqAccordion">
                                        <div class="accordion-body text-secondary small px-0">
                                            During digestion, the stomach churns food and releases it gradually into the small intestine. This delayed stomach emptying and intestinal absorption mean food-based glucose usually peaks between 60 to 90 minutes after your first bite, and declines back to baseline around 2 to 3 hours later.
                                        </div>
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<style>
    /* Styling for Pills */
    #v-pills-tab .nav-link {
        color: var(--text-secondary) !important;
        border-radius: 8px;
        transition: all 0.2s ease;
        border: 1px solid transparent;
        background: transparent;
    }
    #v-pills-tab .nav-link:hover {
        background: rgba(255, 255, 255, 0.03);
        color: var(--text-primary) !important;
    }
    #v-pills-tab .nav-link.active {
        background: rgba(14, 165, 233, 0.1) !important;
        border-color: rgba(14, 165, 233, 0.25) !important;
        color: var(--color-accent-blue) !important;
        font-weight: 600;
    }

    /* Checklist Step Hover Styles */
    .routine-step-item {
        transition: all 0.2s ease;
        border: 1px solid rgba(255,255,255,0.05);
    }
    .routine-step-item:hover {
        border-color: rgba(16, 185, 129, 0.15);
        background: rgba(16, 185, 129, 0.01) !important;
    }

    .cursor-pointer {
        cursor: pointer;
    }

    /* Box Breathing Circle Style */
    .breathing-circle {
        width: 140px;
        height: 140px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(14, 165, 233, 0.3) 0%, rgba(14, 165, 233, 0.05) 75%);
        border: 3px solid rgba(14, 165, 233, 0.3);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 1s ease;
        box-shadow: 0 0 15px rgba(14, 165, 233, 0.1);
    }

    /* Accordion Custom Styling */
    .accordion-button::after {
        filter: invert(1);
    }
    .accordion-item {
        border-color: rgba(255,255,255,0.08) !important;
    }
</style>

@section Scripts {
    <script>
        $(document).ready(function() {
            // --- PERSIST CHECKS IN LOCAL STORAGE ---
            const storageKey = 'glycemic_morning_checklist_' + new Date().toISOString().split('T')[0];
            
            // Load state
            $('.routine-checkbox').each(function() {
                const stepNum = $(this).data('step');
                const isChecked = localStorage.getItem(storageKey + '_step_' + stepNum) === 'true';
                $(this).prop('checked', isChecked);
                if (isChecked) {
                    $(this).closest('.routine-step-item').css('border-color', 'rgba(16, 185, 129, 0.4)');
                }
            });

            // Save state on change
            $('.routine-checkbox').on('change', function() {
                const stepNum = $(this).data('step');
                const isChecked = $(this).is(':checked');
                localStorage.setItem(storageKey + '_step_' + stepNum, isChecked);
                
                if (isChecked) {
                    $(this).closest('.routine-step-item').css('border-color', 'rgba(16, 185, 129, 0.4)');
                } else {
                    $(this).closest('.routine-step-item').css('border-color', 'rgba(255,255,255,0.05)');
                }
            });

            // Clear state
            $('#btnClearChecks').on('click', function() {
                $('.routine-checkbox').prop('checked', false).trigger('change');
            });


            // --- BOX BREATHING LOGIC ---
            let breathInterval = null;
            let currentCycle = 0;
            let currentStage = 0; // 0 = Inhale, 1 = Hold, 2 = Exhale, 3 = Hold
            let stageSeconds = 4;
            
            const stages = [
                { text: 'INHALE', class: 'breath-inhale', color: '#10b981', glow: 'rgba(16, 185, 129, 0.4)', scale: '1.4' },
                { text: 'HOLD', class: 'breath-hold-in', color: '#f59e0b', glow: 'rgba(245, 158, 11, 0.4)', scale: '1.4' },
                { text: 'EXHALE', class: 'breath-exhale', color: '#ef4444', glow: 'rgba(239, 68, 68, 0.4)', scale: '1.0' },
                { text: 'HOLD', class: 'breath-hold-out', color: '#6b7280', glow: 'rgba(107, 114, 128, 0.2)', scale: '1.0' }
            ];

            const $circle = $('#breathCircle');
            const $text = $('#breathText');
            const $timer = $('#breathTimer');
            const $badge = $('#cycleBadge');
            const $btnStart = $('#btnStartBreathing');
            const $btnStop = $('#btnStopBreathing');

            function updateCircleStyle(stage) {
                const info = stages[stage];
                $text.text(info.text).css('color', info.color);
                $circle.css({
                    'transform': 'scale(' + info.scale + ')',
                    'border-color': info.color,
                    'box-shadow': '0 0 25px ' + info.glow,
                    'background': 'radial-gradient(circle, ' + info.glow + ' 0%, rgba(14, 165, 233, 0) 75%)'
                });
            }

            function startBreathing() {
                currentCycle = 1;
                currentStage = 0;
                stageSeconds = 4;
                
                $btnStart.addClass('d-none');
                $btnStop.removeClass('d-none');
                $badge.text('Cycle: ' + currentCycle + ' / 4').removeClass('bg-secondary').addClass('bg-success');
                
                updateCircleStyle(currentStage);
                $timer.text(stageSeconds);

                breathInterval = setInterval(function() {
                    stageSeconds--;
                    
                    if (stageSeconds <= 0) {
                        currentStage++;
                        if (currentStage >= 4) {
                            currentStage = 0;
                            currentCycle++;
                            if (currentCycle > 4) {
                                stopBreathing();
                                // Automatically check the Box Breathing step upon completion!
                                $('#checkStep4').prop('checked', true).trigger('change');
                                return;
                            }
                            $badge.text('Cycle: ' + currentCycle + ' / 4');
                        }
                        stageSeconds = 4;
                    }
                    
                    updateCircleStyle(currentStage);
                    $timer.text(stageSeconds);
                }, 1000);
            }

            function stopBreathing() {
                clearInterval(breathInterval);
                breathInterval = null;
                
                $btnStart.removeClass('d-none');
                $btnStop.addClass('d-none');
                $badge.text('Cycle: 0 / 4').removeClass('bg-success').addClass('bg-secondary');
                $text.text('READY').css('color', '#ffffff');
                $timer.text('--');
                
                $circle.css({
                    'transform': 'scale(1.0)',
                    'border-color': 'rgba(14, 165, 233, 0.3)',
                    'box-shadow': '0 0 15px rgba(14, 165, 233, 0.1)',
                    'background': 'radial-gradient(circle, rgba(14, 165, 233, 0.3) 0%, rgba(14, 165, 233, 0.05) 75%)'
                });
            }

            $btnStart.on('click', startBreathing);
            $btnStop.on('click', stopBreathing);
        });
    </script>
}
