@using GlycemicTracker.Services
@using GlycemicTracker.Models
@{
    ViewData["Title"] = "Dashboard";
    var stats = ViewBag.Stats as GlucoseCalculator.DashboardStats;
    var recentLogs = ViewBag.RecentLogs as List<FoodLog> ?? new List<FoodLog>();
    var recentReadings = ViewBag.RecentReadings as List<GlucoseReading> ?? new List<GlucoseReading>();
}

<!-- Dashboard Header -->
<div class="row align-items-center mb-4">
    <div class="col-md-6">
        <h1 class="mb-1">Glycemic Controller</h1>
        <p class="text-secondary">Tracking food-induced glucose response & glycemic load</p>
    </div>
    <div class="col-md-6 text-md-end">
        <a class="btn btn-outline-info me-2" asp-controller="Home" asp-action="DownloadReport" target="_blank" style="border-radius: 8px; padding: 6px 16px; font-weight: 500;">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-file-earmark-pdf-fill me-1" viewBox="0 0 16 16">
                <path d="M5.523 12.424c.14-.082.293-.162.459-.238a7.878 7.878 0 0 1-.45.606c-.28.33-.52.496-.696.496-.111 0-.185-.053-.223-.157-.04-.112-.007-.272.097-.432.13-.199.37-.367.813-.475zm2.715-4.498a4.953 4.953 0 0 1-.397 1.502 3.14 3.14 0 0 0-.472-.65 2.184 2.184 0 0 1-.365-.733c.122-.317.185-.643.185-.972 0-.255-.026-.463-.077-.625a.48.48 0 0 1 .122-.494c.14-.144.307-.162.409-.008.141.213.123.561-.05 1.047-.101.281-.228.604-.376.93zM10.11 9.616c.074.208.121.412.142.608.02.185-.01.336-.089.452-.08.117-.215.18-.403.18-.402 0-.917-.306-1.545-.918a13.677 13.677 0 0 1-.45-.44c.414-.158.855-.262 1.32-.313a7.493 7.493 0 0 1 .937-.038c.15 0 .285.011.403.033a1.86 1.86 0 0 1 .453.136c.224.09.3.224.232.383z"/>
                <path d="M4 0h5.293A1 1 0 0 1 10 .293L13.707 4a1 1 0 0 1 .293.707V14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2zm5.5 1.5v2a1 1 0 0 0 1 1h2l-3-3zM4.165 13.668c.09.18.23.343.438.419.207.075.412.04.58-.11.317-.283.587-.733.799-1.302.213-.57.355-1.236.42-1.959l-.024-.044c-.387.54-.855.93-1.378 1.157-.538.232-.974.272-1.21.08-.261-.212-.3-.633-.108-1.157.199-.543.615-.997 1.156-1.294.062-.034.129-.065.197-.095a8.564 8.564 0 0 1-.185-1.05c-.19-.76-.324-1.48-.396-2.137a11.196 11.196 0 0 1-.228-1.57c-.062-.531-.026-.947.108-1.216.145-.29.414-.424.712-.352.327.08.577.34.707.747.201.63.12 1.455-.19 2.396-.183.548-.466 1.201-.811 1.84a7.86 7.86 0 0 1 .218 1.22c.07.49.123.94.158 1.332a8.88 8.88 0 0 1 1.62-.077c.4-.003.75.05 1.02.154.278.107.453.284.51.52.052.222-.047.533-.314.779-.276.255-.632.378-1.012.378-.838 0-1.604-.472-2.185-1.397a7.58 7.58 0 0 1-.275-.485c-.061.222-.153.446-.273.671-.35.66-.82 1.11-1.3 1.306z"/>
            </svg>
            PDF Report
        </a>
        <div class="btn-group" role="group">
            <button type="button" class="btn chart-time-toggle active" data-range="Today" onclick="initializeGlucoseChart('Today')">Today</button>
            <button type="button" class="btn chart-time-toggle" data-range="Last24Hours" onclick="initializeGlucoseChart('Last24Hours')">Last 24h</button>
            <button type="button" class="btn chart-time-toggle" data-range="Yesterday" onclick="initializeGlucoseChart('Yesterday')">Yesterday</button>
        </div>
    </div>
</div>

<!-- Stats Row -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-4 col-lg-2">
        <div class="glass-panel stats-card" id="currentGlucoseCard" data-bs-toggle="tooltip" data-bs-html="true" data-bs-placement="top" title="&lt;strong class='text-info'&gt;Current Est. Glucose&lt;/strong&gt;&lt;br/&gt;Estimated blood glucose right now, simulated from your food log timeline.&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Reference Ranges:&lt;/b&gt;&lt;br/&gt;&bull; Fasting: 4.0 - 5.9 mmol/L&lt;br/&gt;&bull; Post-meal: &amp;lt; 7.8 mmol/L&lt;br/&gt;&bull; Spike: &amp;ge; 7.8 mmol/L">
            <div class="stats-title">Current Est.</div>
            <div class="stats-value text-info" id="statCurrentGlucose">@stats?.CurrentGlucose.ToString("0.0")</div>
            <div class="stats-unit">mmol/L</div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
        <div class="glass-panel stats-card" id="peakGlucoseCard" data-bs-toggle="tooltip" data-bs-html="true" data-bs-placement="top" title="&lt;strong class='text-danger'&gt;Peak Glucose Today&lt;/strong&gt;&lt;br/&gt;The highest estimated or recorded glucose level today.&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Clinical Target:&lt;/b&gt;&lt;br/&gt;&bull; Aim to keep peaks &amp;lt; 7.8 mmol/L to reduce glycation and stress on insulin production.">
            <div class="stats-title">Peak Today</div>
            <div class="stats-value text-danger" id="statPeakGlucose">@stats?.PeakGlucoseToday.ToString("0.0")</div>
            <div class="stats-unit">mmol/L</div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
        <div class="glass-panel stats-card accent-green" data-bs-toggle="tooltip" data-bs-html="true" data-bs-placement="top" title="&lt;strong class='text-success'&gt;Time In Range (TIR)&lt;/strong&gt;&lt;br/&gt;Percentage of the day where estimated glucose remains in the safe zone (4.0 - 7.8 mmol/L).&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Clinical Target:&lt;/b&gt;&lt;br/&gt;&bull; Target: &amp;ge; 70% of the day (higher is better). High TIR correlates with low HbA1c.">
            <div class="stats-title">Time In Range</div>
            <div class="stats-value text-success" id="statTIR">@stats?.TimeInRangePercentage.ToString("0")%</div>
            <div class="stats-unit">4.0 - 7.8 mmol/L</div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
        <div class="glass-panel stats-card accent-red" data-bs-toggle="tooltip" data-bs-html="true" data-bs-placement="top" title="&lt;strong class='text-danger'&gt;Red Zone Time&lt;/strong&gt;&lt;br/&gt;Total accumulated minutes today spent above the spike threshold of 7.8 mmol/L.&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Clinical Target:&lt;/b&gt;&lt;br/&gt;&bull; Aim for 0 minutes. Extended time above 7.8 mmol/L causes endothelial damage and increases HbA1c.">
            <div class="stats-title">Red Zone</div>
            <div class="stats-value text-danger" id="statRedZone">@(stats?.MinutesInRedZoneToday)m</div>
            <div class="stats-unit">Above 7.8 mmol/L</div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
        <div class="glass-panel stats-card accent-orange" data-bs-toggle="tooltip" data-bs-html="true" data-bs-placement="top" title="&lt;strong class='text-warning'&gt;Total Carbs Today&lt;/strong&gt;&lt;br/&gt;Total weight of carbohydrates consumed today.&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Impact on Glucose:&lt;/b&gt;&lt;br/&gt;&bull; Carbs are the primary driver of glucose rises. Pair carbs with protein, fat, and fiber to flatten spikes.">
            <div class="stats-title">Total Carbs</div>
            <div class="stats-value text-warning" id="statCarbs">@stats?.TotalCarbsToday.ToString("0")g</div>
            <div class="stats-unit">Consumed today</div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
        <div class="glass-panel stats-card accent-blue" data-bs-toggle="tooltip" data-bs-html="true" data-bs-placement="top" title="&lt;strong class='text-info'&gt;Average Glycemic Index&lt;/strong&gt;&lt;br/&gt;Average rate at which consumed foods convert to glucose, weighted by carb weight.&lt;br/&gt;&lt;br/&gt;&lt;b&gt;GI Reference:&lt;/b&gt;&lt;br/&gt;&bull; Low (&amp;le; 55): Slow absorption (Ideal)&lt;br/&gt;&bull; Medium (56-69): Moderate rise&lt;br/&gt;&bull; High (&amp;ge; 70): Rapid absorption &amp; spikes">
            <div class="stats-title">Avg GI</div>
            <div class="stats-value text-info" id="statAvgGI">@stats?.AverageGiToday.ToString("0")</div>
            <div class="stats-unit">Glycemic Index</div>
        </div>
    </div>
</div>

<!-- Main Interactive Chart -->
<div class="row mb-4">
    <div class="col-12">
        <div class="glass-panel">
            <h4 class="mb-3 d-flex align-items-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-graph-up text-primary me-2" viewBox="0 0 16 16">
                    <path fill-rule="evenodd" d="M0 0h1v15h15v1H0V0Zm14.817 3.113a.5.5 0 0 1 .07.704l-4.5 5.5a.5.5 0 0 1-.74.037L7.06 6.767l-3.656 5.027a.5.5 0 0 1-.808-.588l4-5.5a.5.5 0 0 1 .758-.06l2.609 2.61 4.15-5.073a.5.5 0 0 1 .704-.07Z"/>
                </svg>
                Glucose Response Simulation
            </h4>
            <div class="chart-container">
                <canvas id="glucoseChart"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- Actions (Food Log & Glucose Log) -->
<div class="row g-4 mb-4">
    <!-- Log Food Form -->
    <div class="col-lg-7">
        <div class="glass-panel h-100">
            <h4 class="mb-3 text-info">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-plus-circle me-2" viewBox="0 0 16 16">
                    <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                    <path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4z"/>
                </svg>
                Quick Food Log
            </h4>
            <form asp-controller="Logs" asp-action="AddFoodLog" method="post">
                <input type="hidden" id="selectedFoodId" name="foodId" required />
                <input type="hidden" id="timeOffsetMinutes" name="timeOffsetMinutes" value="0" />

                <!-- Search Input -->
                <div class="mb-3">
                    <label for="foodSearchInput" class="form-label text-secondary">Search Food Item</label>
                    <input type="text" class="form-control" id="foodSearchInput" placeholder="Type to search (e.g. white rice, banana, eggs...)" autocomplete="off" />
                </div>

                <!-- Selected Food Detail Alert (grows/collapses) -->
                <div id="foodSelectedAlert" class="alert d-none mb-3 py-3" style="background: rgba(25, 33, 52, 0.6); border: 1px solid var(--border-color); border-radius: 10px;">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <strong class="text-white" id="selectedFoodName">Food Name</strong>
                        <span class="badge badge-gi" id="selectedFoodGIBadge">Low GI</span>
                    </div>
                    <div class="row g-2 text-center text-secondary" style="font-size: 0.82rem;">
                        <div class="col-2"><div class="fw-bold text-white" id="selectedFoodGI">0</div>GI</div>
                        <div class="col-2"><div class="fw-bold text-warning" id="selectedFoodCarbs">0g</div>Carbs</div>
                        <div class="col-2"><div class="fw-bold text-warning" id="selectedFoodSugar">0g</div>Sugar</div>
                        <div class="col-2"><div class="fw-bold text-success" id="selectedFoodProtein">0g</div>Prot</div>
                        <div class="col-2"><div class="fw-bold text-info" id="selectedFoodFat">0g</div>Fat</div>
                        <div class="col-2"><div class="fw-bold text-success" id="selectedFoodFiber">0g</div>Fiber</div>
                    </div>
                </div>

                <div class="row mb-3">
                    <!-- Amount input -->
                    <div class="col-md-5">
                        <label for="portionGramsInput" class="form-label text-secondary">Portion Size</label>
                        <div class="input-group">
                            <input type="number" class="form-control" id="portionGramsInput" name="amountGrams" value="100" min="1" step="1" required />
                            <span class="input-group-text bg-dark border-secondary text-secondary">grams</span>
                        </div>
                        <div id="portionHelperText" class="form-text text-info mt-1 d-none" style="font-size: 0.8rem;"></div>
                    </div>
                    
                    <!-- Quick Time Offset buttons -->
                    <div class="col-md-7">
                        <label class="form-label text-secondary">When did you eat this?</label>
                        <div class="d-flex flex-wrap">
                            <button type="button" class="btn btn-primary time-preset-btn" data-offset="0">Now</button>
                            <button type="button" class="btn btn-secondary time-preset-btn" data-offset="15">-15m</button>
                            <button type="button" class="btn btn-secondary time-preset-btn" data-offset="30">-30m</button>
                            <button type="button" class="btn btn-secondary time-preset-btn" data-offset="60">-1h</button>
                            <button type="button" class="btn btn-secondary time-preset-btn" data-offset="120">-2h</button>
                            <button type="button" class="btn btn-secondary time-preset-btn" data-offset="custom">Custom</button>
                        </div>
                    </div>
                </div>

                <!-- Custom DateTime Input (shown only when custom is clicked) -->
                <div class="mb-3 d-none" id="customTimeContainer">
                    <label for="logTimeStr" class="form-label text-secondary">Select Custom Date & Time (Backdate)</label>
                    <input type="datetime-local" class="form-control" id="logTimeStr" name="logTimeStr" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
                </div>

                <!-- Calculations Preview -->
                <div class="mb-3 p-3" style="background: rgba(25, 33, 52, 0.4); border: 1px dashed var(--border-color); border-radius: 10px;">
                    <span class="text-secondary" style="font-size: 0.85rem;">Meal Impact Estimate:</span>
                    <div class="d-flex justify-content-between align-items-center mt-1">
                        <div>
                            <span class="text-secondary me-2">Carbohydrates:</span>
                            <strong class="text-warning" id="previewCarbs">0.0g</strong>
                        </div>
                        <div class="d-flex align-items-center">
                            <span class="text-secondary me-2">Glycemic Load:</span>
                            <strong class="text-info me-2" id="previewGL">0.0</strong>
                            <span class="badge badge-gi gi-low" id="previewGLBadge" style="font-size: 0.75rem;">Low GL</span>
                        </div>
                    </div>
                </div>

                <div class="text-end">
                    <button type="submit" class="btn btn-primary w-100" id="btnSubmitLog" disabled>
                        Log Food Consumption
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Log Actual Glucose Value Form -->
    <div class="col-lg-5">
        <div class="glass-panel h-100">
            <h4 class="mb-3 text-danger">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-droplet-fill me-2" viewBox="0 0 16 16">
                    <path d="M8 16a6 6 0 0 0 6-6c0-1.667-1.213-4.5-6-10.056L8 0 7.999.006C3.21 5.56 2 8.388 2 10a6 6 0 0 0 6 6Z"/>
                </svg>
                Log Blood Glucose
            </h4>
            <form asp-controller="Logs" asp-action="AddGlucoseReading" method="post">
                <div class="mb-3">
                    <label for="glucoseValueInput" class="form-label text-secondary">Finger Prick / Sensor Reading</label>
                    <div class="input-group">
                        <input type="number" class="form-control" id="glucoseValueInput" name="glucoseValue" min="1.0" max="35.0" step="0.1" placeholder="e.g. 5.8" required />
                        <span class="input-group-text bg-dark border-secondary text-secondary">mmol/L</span>
                    </div>
                    <div class="form-text text-muted" style="font-size:0.75rem;">Spikes are defined as postprandial glucose &ge; 7.8 mmol/L.</div>
                </div>

                <div class="mb-3">
                    <label for="readingTimeStr" class="form-label text-secondary">Reading Date & Time</label>
                    <input type="datetime-local" class="form-control" id="readingTimeStr" name="readingTimeStr" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" required />
                </div>

                <div class="text-end pt-2">
                    <button type="submit" class="btn btn-primary bg-danger border-danger w-100" style="box-shadow: 0 4px 12px rgba(239, 68, 68, 0.3);">
                        Record Measurement
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- History lists -->
<div class="row g-4">
    <!-- Recent Food Log List -->
    <div class="col-lg-7">
        <div class="glass-panel">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="m-0 text-info">Recent Food Logs</h4>
                <a class="btn btn-sm btn-secondary" asp-controller="Foods" asp-action="Index">Manage Food Library</a>
            </div>
            
            @if (recentLogs.Count == 0)
            {
                <p class="text-secondary py-3 text-center">No foods logged today. Type in the box above to log your first meal!</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-dark table-hover align-middle" style="background: transparent;">
                        <thead>
                            <tr class="text-secondary" style="border-bottom: 2px solid var(--border-color);">
                                <th>Time</th>
                                <th>Food Item</th>
                                <th class="text-center">Amount</th>
                                <th class="text-center">Carbs</th>
                                <th class="text-center">GI</th>
                                <th class="text-center">GL</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in recentLogs)
                            {
                                <tr style="border-bottom: 1px solid var(--border-color);">
                                    <td class="text-nowrap text-secondary" style="font-size:0.85rem;">@log.LogTime.ToString("HH:mm")</td>
                                    <td>
                                        <div class="fw-semibold">@log.FoodName</div>
                                    </td>
                                    <td class="text-center">@log.AmountGrams.ToString("0")g</td>
                                    <td class="text-center text-warning">@log.CarbsGrams.ToString("0.0")g</td>
                                    <td class="text-center">
                                        @{
                                            var giClass = "gi-low";
                                            if (log.GlycemicIndex > 70) giClass = "gi-high";
                                            else if (log.GlycemicIndex > 55) giClass = "gi-medium";
                                        }
                                        <span class="badge badge-gi @giClass" style="font-size:0.75rem; padding: 4px 6px;">@log.GlycemicIndex</span>
                                    </td>
                                    <td class="text-center text-info">@log.GlycemicLoad.ToString("0.0")</td>
                                    <td class="text-end">
                                        <form asp-controller="Logs" asp-action="DeleteFoodLog" method="post" onsubmit="return confirm('Delete this food log?');">
                                            <input type="hidden" name="id" value="@log.Id" />
                                            <button type="submit" class="btn btn-link text-danger p-0" style="text-decoration:none;">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-trash" viewBox="0 0 16 16">
                                                    <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5Zm2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5Zm3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V6Z"/>
                                                    <path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1v1ZM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4H4.118ZM2.5 3h11V2h-11v1Z"/>
                                                </svg>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <!-- Recent Glucose Readings List -->
    <div class="col-lg-5">
        <div class="glass-panel">
            <h4 class="mb-3 text-danger">Recorded Readings</h4>
            
            @if (recentReadings.Count == 0)
            {
                <p class="text-secondary py-3 text-center">No actual glucose readings recorded yet.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-dark table-hover align-middle" style="background: transparent;">
                        <thead>
                            <tr class="text-secondary" style="border-bottom: 2px solid var(--border-color);">
                                <th>Time</th>
                                <th class="text-center">Reading</th>
                                <th>Notes</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var reading in recentReadings)
                            {
                                <tr style="border-bottom: 1px solid var(--border-color);">
                                    <td class="text-nowrap text-secondary" style="font-size:0.85rem;">@reading.ReadingTime.ToString("MMM dd HH:mm")</td>
                                    <td class="text-center">
                                        <span class="fw-bold @(reading.GlucoseValue >= 7.8 ? "text-danger" : "text-success")">
                                            @reading.GlucoseValue.ToString("0.0")
                                        </span>
                                        <span class="text-secondary" style="font-size:0.75rem;">mmol/L</span>
                                    </td>
                                    <td class="text-truncate" style="max-width: 150px; font-size:0.85rem;" title="@reading.Notes">@reading.Notes</td>
                                    <td class="text-end">
                                        <form asp-controller="Logs" asp-action="DeleteGlucoseReading" method="post" onsubmit="return confirm('Delete this reading?');">
                                            <input type="hidden" name="id" value="@reading.Id" />
                                            <button type="submit" class="btn btn-link text-danger p-0" style="text-decoration:none;">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-trash" viewBox="0 0 16 16">
                                                    <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5Zm2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5Zm3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V6Z"/>
                                                    <path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1v1ZM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4H4.118ZM2.5 3h11V2h-11v1Z"/>
                                                </svg>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
